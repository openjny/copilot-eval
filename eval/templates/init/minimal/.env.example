# Environment variables copilot-eval needs. These must be exported in your
# shell (or set as CI secrets/env vars) — copilot-eval reads them directly
# from the process environment; there is no ".env file" auto-loading for
# this host-side check (see `eval.runner.get_github_token` /
# `eval.validation.check_github_token`).
#   export COPILOT_GITHUB_TOKEN=ghp_...

# Required: token Copilot CLI authenticates with, and that `docker build`
# uses to install it into the image. `GITHUB_TOKEN` also works as a fallback
# (checked first). If neither is exported, `gh auth token` is used as a last
# resort — i.e. running `gh auth login` once is enough and you can leave
# this unset.
COPILOT_GITHUB_TOKEN=

# Optional: a `.env` file placed at the REPO ROOT (not this project
# directory) is loaded for task hooks/health-check scripts and passed into
# the eval container's environment — see docs/configuration.md#secrets--env.
# Add extra variables your hooks/tasks need there, e.g. cloud credentials.
