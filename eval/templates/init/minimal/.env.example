# Template for .env — copy to .env and fill in values, then `.env` stays
# untracked (see .gitignore). Used by `copilot-eval run`/`build`.
# cp .env.example .env

# Required: GitHub token Copilot CLI authenticates with inside the container.
# `GITHUB_TOKEN` also works as a fallback (checked first). If neither is set,
# `gh auth token` is used as a last resort — see docs/configuration.md#secrets--env.
COPILOT_GITHUB_TOKEN=

# Optional: add any additional environment variables your tasks/hooks need
# below (e.g. cloud provider credentials for hooks that provision fixtures).
